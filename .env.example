# Demo runs WITHOUT any of these set — the offline stub translator produces
# inspectable output so the full pipeline can be verified locally.

# Pick a backend for real translation
TRANSLATOR_BACKEND=stub   # stub | google | anthropic

# Force offline mode regardless of TRANSLATOR_BACKEND
OFFLINE=1

# Anthropic backend
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
